generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum MarketCode {
  AU
  SG
  HK
  CN
  GLOBAL
}

enum ApplicationStatus {
  SAVED
  PREPARED
  APPLIED
  OA
  INTERVIEW
  REJECTED
  OFFER
  SKIPPED
}

enum SourceType {
  MANUAL
  ADZUNA
  ATS
  EMAIL_ALERT
  COMPANY_SITE
}

enum Sensitivity {
  SAFE
  REVIEW
  SENSITIVE
}

model CandidateProfile {
  id        String   @id @default(cuid())
  name      String
  headline  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fields CandidateProfileField[]
}

model CandidateProfileField {
  id        String      @id @default(cuid())
  profileId String
  key       String
  label     String
  value     String
  market    MarketCode?
  sensitivity Sensitivity @default(SAFE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile CandidateProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, key, market])
}

model ResumeAsset {
  id         String     @id @default(cuid())
  name       String
  market     MarketCode?
  roleFamily String
  filePath   String?
  content    String?
  version    Int        @default(1)
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  applications Application[]
}

model JobSource {
  id          String     @id @default(cuid())
  name        String
  market      MarketCode
  sourceType  SourceType
  baseUrl     String?
  enabled     Boolean    @default(true)
  reliability Int        @default(70)
  lastSyncedAt DateTime?
  createdAt   DateTime   @default(now())

  jobs          Job[]
  importBatches JobImportBatch[]
  syncLogs      SourceSyncLog[]
}

model Job {
  id            String     @id @default(cuid())
  sourceId      String?
  importBatchId String?
  market        MarketCode
  title         String
  company       String
  location      String?
  sourceUrl     String?
  description   String
  language      String     @default("en")
  postedAt      DateTime?
  firstSeenAt   DateTime   @default(now())
  lastSeenAt    DateTime   @default(now())
  matchScore    Int?
  visaRisk      String?
  graduateFit   String?
  archived      Boolean    @default(false)
  sourceHash    String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  source       JobSource?      @relation(fields: [sourceId], references: [id])
  importBatch  JobImportBatch? @relation(fields: [importBatchId], references: [id])
  parseResult  JobParseResult?
  applications Application[]
  applyTasks   ApplyTask[]
  materialDrafts MaterialDraft[]
  autofillContexts AutofillContext[]
}

model JobImportBatch {
  id            String     @id @default(cuid())
  sourceId      String?
  sourceName    String
  importType    String
  rawText       String?
  issuesJson    String?
  totalCount    Int        @default(0)
  importedCount Int        @default(0)
  dedupedCount  Int        @default(0)
  skippedCount  Int        @default(0)
  errorCount    Int        @default(0)
  createdAt     DateTime   @default(now())

  source JobSource? @relation(fields: [sourceId], references: [id])
  jobs   Job[]
}

model JobParseResult {
  id                  String   @id @default(cuid())
  jobId               String   @unique
  rawText             String?
  keywordsJson        String?
  positiveReasonsJson String?
  negativeReasonsJson String?
  riskSignalsJson     String?
  deadline            DateTime?
  confidence          Int      @default(70)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model DailyApplyPlan {
  id          String   @id @default(cuid())
  planDate    DateTime
  targetCount Int      @default(5)
  status      String   @default("pending")
  generatedAt DateTime @default(now())
  completedAt DateTime?

  tasks ApplyTask[]
}

model ApplyTask {
  id          String   @id @default(cuid())
  planId      String
  jobId       String
  priority    Int      @default(50)
  status      String   @default("queued")
  matchScore  Int?
  riskLevel   String?
  skipReason  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plan DailyApplyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  job  Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  package ApplicationPackage?
}

model ApplicationPackage {
  id                 String   @id @default(cuid())
  applyTaskId         String   @unique
  coverLetterDraft    String?
  screenerAnswersJson String?
  checklistJson       String?
  generatedAt         DateTime @default(now())

  applyTask ApplyTask @relation(fields: [applyTaskId], references: [id], onDelete: Cascade)
}

model Application {
  id         String            @id @default(cuid())
  jobId      String
  resumeId   String?
  status     ApplicationStatus @default(SAVED)
  appliedAt  DateTime?
  responseAt DateTime?
  nextAction String?
  nextActionAt DateTime?
  notes      String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  job    Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume ResumeAsset? @relation(fields: [resumeId], references: [id])
  autofillRuns AutofillRun[]
  formSnapshots FormSnapshot[]
  autofillContexts AutofillContext[]
}

model ResumeVersion {
  id         String     @id @default(cuid())
  name       String
  market     MarketCode?
  roleFamily String
  language   String     @default("zh")
  content    String
  isDefault  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  materialDrafts MaterialDraft[]
}

model MaterialDraft {
  id              String   @id @default(cuid())
  jobId           String
  resumeVersionId String?
  draftType       String
  title           String
  content         String
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  job           Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeVersion ResumeVersion? @relation(fields: [resumeVersionId], references: [id])
}

model SourceSyncLog {
  id          String   @id @default(cuid())
  sourceId    String?
  action      String
  status      String
  message     String?
  createdAt   DateTime @default(now())

  source JobSource? @relation(fields: [sourceId], references: [id])
}

model AutofillRun {
  id             String   @id @default(cuid())
  applicationId  String?
  snapshotId     String?
  url            String
  atsVendor      String?
  mode           String   @default("scan")
  fieldsDetected Int
  fieldsFilled   Int
  fieldsSkipped  Int
  createdAt      DateTime @default(now())

  application Application? @relation(fields: [applicationId], references: [id])
  snapshot    FormSnapshot? @relation(fields: [snapshotId], references: [id])
  snapshots   FormFieldSnapshot[]
  corrections AutofillCorrection[]
}

model AutofillContext {
  id            String   @id
  applicationId String?
  jobId         String?
  urlHint       String?
  hostHint      String?
  status        String   @default("active")
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  job         Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
}

model FormFieldSnapshot {
  id          String   @id @default(cuid())
  autofillRunId String
  url         String
  label       String
  inputName   String?
  inputType   String?
  detectedKey String?
  confidence  Int      @default(0)
  createdAt   DateTime @default(now())

  autofillRun AutofillRun @relation(fields: [autofillRunId], references: [id], onDelete: Cascade)
}

model FormSnapshot {
  id          String   @id @default(cuid())
  applicationId String?
  url         String
  host        String?
  title       String?
  atsVendor   String?
  source      String   @default("EDGE")
  fieldCount  Int      @default(0)
  safeCount   Int      @default(0)
  reviewCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  fields FormField[]
  runs   AutofillRun[]
}

model FormField {
  id               String      @id @default(cuid())
  snapshotId       String
  fieldFingerprint String
  label            String
  inputName        String?
  inputId          String?
  inputType        String?
  placeholder      String?
  required         Boolean     @default(false)
  detectedKey      String?
  mappedKey        String?
  sensitivity      Sensitivity @default(REVIEW)
  confidence       Int         @default(0)
  selector         String?
  optionsJson      String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  snapshot     FormSnapshot         @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  mappingRules FieldMappingRule[]
  corrections  AutofillCorrection[]

  @@unique([snapshotId, fieldFingerprint])
}

model FieldMappingRule {
  id               String      @id @default(cuid())
  formFieldId      String?
  host             String?
  atsVendor        String?
  fieldFingerprint String?
  labelPattern     String
  inputName        String?
  candidateKey     String
  sensitivity      Sensitivity @default(SAFE)
  confidence       Int         @default(90)
  enabled          Boolean     @default(true)
  source           String      @default("manual")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  formField   FormField?            @relation(fields: [formFieldId], references: [id], onDelete: SetNull)
  corrections AutofillCorrection[]
}

model AutofillCorrection {
  id            String   @id @default(cuid())
  runId         String?
  formFieldId   String?
  mappingRuleId String?
  previousKey   String?
  correctedKey  String
  note          String?
  createdAt     DateTime @default(now())

  run         AutofillRun?      @relation(fields: [runId], references: [id], onDelete: SetNull)
  formField   FormField?        @relation(fields: [formFieldId], references: [id], onDelete: SetNull)
  mappingRule FieldMappingRule? @relation(fields: [mappingRuleId], references: [id], onDelete: SetNull)
}

model AnswerVaultItem {
  id          String     @id @default(cuid())
  question    String
  answer      String
  market      MarketCode?
  roleFamily  String?
  sensitivity Sensitivity @default(REVIEW)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}
